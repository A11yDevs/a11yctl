is_sensitive_command() {
    local -a cmd=("$@")
    local i

    if [[ ${#cmd[@]} -eq 0 ]]; then
        return 1
    fi

    case "${cmd[0]}" in
        uninstall)
            return 0
            ;;
        host)
            if [[ "${cmd[1]:-}" == 'install' ]] || [[ "${cmd[1]:-}" == '-i' ]]; then
                return 0
            fi
            ;;
        vm)
            if [[ "${cmd[1]:-}" == 'remove' ]] || [[ "${cmd[1]:-}" == '-r' ]] || [[ "${cmd[1]:-}" == 'delete' ]]; then
                return 0
            fi
            if [[ "${cmd[1]:-}" == 'config' ]] && [[ "${cmd[2]:-}" == 'reset' ]]; then
                return 0
            fi
            ;;
        self-update|update)
            for ((i=1; i<${#cmd[@]}; i++)); do
                if [[ "${cmd[$i]}" == '--force' ]] || [[ "${cmd[$i]}" == '-f' ]]; then
                    return 1
                fi
            done
            return 0
            ;;
    esac

    return 1
}

show_sensitive_notice() {
    local -a cmd=("$@")

    if [[ "${cmd[0]}" == 'vm' ]] && [[ "${cmd[1]:-}" == 'config' ]] && [[ "${cmd[2]:-}" == 'reset' ]]; then
        echo 'Esta ação pode redefinir configurações da VM.'
        echo 'Nenhuma configuração pessoal deve ser apagada sem confirmação explícita.'
        return 0
    fi

    if [[ "${cmd[0]}" == 'host' ]] && ([[ "${cmd[1]:-}" == 'install' ]] || [[ "${cmd[1]:-}" == '-i' ]]); then
        echo 'Esta ação iniciará a instalação nativa no host.'
        echo 'Ela pode instalar pacotes e alterar arquivos do sistema.'
        return 0
    fi

    if [[ "${cmd[0]}" == 'vm' ]] && ([[ "${cmd[1]:-}" == 'remove' ]] || [[ "${cmd[1]:-}" == '-r' ]] || [[ "${cmd[1]:-}" == 'delete' ]]); then
        echo 'Esta ação pode remover arquivos da VM.'
        return 0
    fi

    if [[ "${cmd[0]}" == 'uninstall' ]]; then
        echo 'Esta ação pode desinstalar a CLI local.'
        return 0
    fi

    if [[ "${cmd[0]}" == 'self-update' ]]; then
        echo 'Esta ação atualiza a CLI e altera arquivos locais da instalação.'
        return 0
    fi

    echo 'Esta ação altera estado persistente.'
}

confirm_sensitive_command() {
    local -a cmd=("$@")
    local reply

    echo
    echo 'Comando equivalente:'
    echo "a11yctl ${cmd[*]}"
    echo

    show_sensitive_notice "${cmd[@]}"
    printf 'Continuar? [s/N] '
    read -r reply || true

    reply="$(printf '%s' "$reply" | tr '[:upper:]' '[:lower:]')"
    case "$reply" in
        s|sim|y|yes)
            return 0
            ;;
        *)
            echo 'Ação cancelada.'
            return 1
            ;;
    esac
}

list_context_commands() {
    local context="$1"
    case "$context" in
        root)
            printf '%s\n' help '?' version self-update update migrate migrate-state uninstall vm host status debug clear exit quit
            ;;
        vm)
            printf '%s\n' help '?' install version check-update list start stop close remove delete diagnose status ssh host-share config optimize debug back exit quit clear
            ;;
        vm_config)
            printf '%s\n' help '?' show --raw list get set path reset debug back exit quit clear
            ;;
        vm_host_share)
            printf '%s\n' help '?' list debug back exit quit clear
            ;;
        host)
            printf '%s\n' help '?' install debug back exit quit clear
            ;;
    esac
}

suggest_command() {
    local context="$1"
    local typed="$2"
    local cmd
    local -a suggestions=()

    while IFS= read -r cmd; do
        [[ -z "$cmd" ]] && continue
        if [[ "$cmd" == "$typed"* ]] || [[ "$cmd" == *"$typed"* ]]; then
            suggestions+=("$cmd")
        fi
    done < <(list_context_commands "$context")

    if [[ ${#suggestions[@]} -gt 0 ]]; then
        echo
        echo 'Talvez você quis dizer:'
        local suggestion
        for suggestion in "${suggestions[@]}"; do
            echo "$suggestion"
        done
    fi
}

is_context_command() {
    local context="$1"
    local typed="$2"
    local cmd

    [[ -z "$typed" ]] && return 1

    while IFS= read -r cmd; do
        [[ -z "$cmd" ]] && continue
        if [[ "$cmd" == "$typed" ]]; then
            return 0
        fi
    done < <(list_context_commands "$context")

    return 1
}

dispatch_host_command() {
    local command="${1:-}"
    shift || true

    case "$command" in
        help|-h|--help)
            show_help
            ;;
        debug)
            invoke_debug_command "${1:-status}"
            ;;
        version|--version)
            invoke_version_command "$@"
            ;;
        self-update|update)
            invoke_self_update "$@"
            ;;
        migrate|migrate-state)
            invoke_migrate_state_command "$@"
            ;;
        uninstall)
            invoke_uninstall "$@"
            ;;
        vm)
            invoke_vm_command "$@"
            ;;
        host)
            invoke_host_command_main "$@"
            ;;
        '')
            show_help
            return 0
            ;;
        *)
            ea11_error "Comando desconhecido no contexto host: $command"
            show_help
            return 1
            ;;
    esac
}

dispatch_command() {
    local context="$1"
    shift || true
    local command="${1:-}"
    shift || true

    if [[ "$context" == 'guest' ]]; then
        case "$command" in
            help|-h|--help)
                show_help
                ;;
            version|--version)
                invoke_version_command "$@"
                ;;
            share|-S)
                invoke_guest_share_command "$@"
                ;;
            '')
                show_help
                return 0
                ;;
            *)
                ea11_error "Comando desconhecido no contexto guest: $command"
                show_help
                return 1
                ;;
        esac
        return 0
    fi

    dispatch_host_command "$command" "$@"
}

start_interactive_shell() {
    local context='root'
    local line

    echo 'a11yctl - modo interativo'
    echo
    echo 'Digite help para ver comandos.'
    echo 'Digite exit para sair.'
    echo

    while true; do
        local prompt
        prompt="$(interactive_prompt "$context")"
        if ! IFS= read -r -p "$prompt" line; then
            echo
            break
        fi

        if ! parse_interactive_line "$line"; then
            continue
        fi

        normalize_aliases "$context" "${INTERACTIVE_TOKENS[@]}"
        resolve_context_command "$context" "${NORMALIZED_TOKENS[@]}"

        case "$RESOLVE_ACTION" in
            noop)
                continue
                ;;
            help)
                show_context_help "$context"
                continue
                ;;
            clear)
                clear 2>/dev/null || printf '\033c'
                continue
                ;;
            exit)
                break
                ;;
            back)
                if [[ "$context" == 'root' ]]; then
                    echo 'Você já está no contexto raiz.'
                else
                    context="$RESOLVE_NEXT_CONTEXT"
                fi
                continue
                ;;
            enter_context)
                context="$RESOLVE_NEXT_CONTEXT"
                continue
                ;;
            status_unavailable)
                echo 'Não há status específico neste contexto.'
                continue
                ;;
            debug_toggle)
                set_interactive_debug_mode "${NORMALIZED_TOKENS[1]:-status}"
                continue
                ;;
        esac

        if [[ ${#RESOLVED_COMMAND[@]} -eq 0 ]]; then
            continue
        fi

        if is_sensitive_command "${RESOLVED_COMMAND[@]}"; then
            if ! confirm_sensitive_command "${RESOLVED_COMMAND[@]}"; then
                continue
            fi
        fi

        if ! dispatch_host_command "${RESOLVED_COMMAND[@]}"; then
            if ! is_context_command "$context" "${NORMALIZED_TOKENS[0]}"; then
                echo
                echo "Comando desconhecido: ${NORMALIZED_TOKENS[0]}"
                suggest_command "$context" "${NORMALIZED_TOKENS[0]}"
            fi
            echo
            echo 'Digite help para ver os comandos disponíveis.'
        fi
    done
}

