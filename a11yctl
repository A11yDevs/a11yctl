main() {
    local context
    context=$(get_execution_context)
    local command="${1:-}"
    if [[ "$context" == 'host' ]] && [[ -z "$command" ]]; then
        start_interactive_shell
        return 0
    fi

    dispatch_command "$context" "$@"
    return $?
}

# Executar main com tratamento de erro
