#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TARGET_SCRIPT="$SCRIPT_DIR/a11yctl"

if [[ ! -f "$TARGET_SCRIPT" ]]; then
    printf '\033[31m[ea11ctl] Nao foi possivel localizar o script a11yctl.\033[0m\n' >&2
    exit 1
fi

printf '\033[33m[ea11ctl] Aviso: ea11ctl esta obsoleto e sera removido em versao futura. Use a11yctl.\033[0m\n' >&2
exec "$TARGET_SCRIPT" "$@"
